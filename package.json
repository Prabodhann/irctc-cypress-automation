{
  "name": "irctc-cypress-automation",
  "version": "3.0.4",
  "description": "IRCTC Ticket Booking",
  "scripts": {
    "start-captha-server": "python irctc-captcha-solver/app-server.py --host 0.0.0.0 --port 5001",
    "wait-for-captha-server-to-come-up": "wait-on http://localhost:5001",
    "start-irctc-booking": "playwright test tests/irctc.spec.ts --headed",
    "start-booking": "concurrently \"npm run start-captha-server\" \"npm run wait-for-captha-server-to-come-up && npm run start-irctc-booking\"",
    "test": "playwright test"
  },
  "author": "Shivam Pandey",
  "license": "ISC",
  "dependencies": {
    "cypress": "13.7.1",
    "dayjs": "^1.11.10",
    "fs.promises": "^0.1.2",
    "wait-on": "^8.0.1"
  },
  "devDependencies": {
    "@cypress/puppeteer": "^0.1.8",
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.1.0",
    "dotenv": "^17.3.1",
    "playwright": "^1.58.2",
    "puppeteer": "^21.11.0"
  }
}
